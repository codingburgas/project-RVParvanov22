@model MicrobloggingSystem.Models.DTOs.Auth.LoginDto

<div class="auth-page auth-page-simple">
    <section class="auth-form-shell">
        <h1 class="mb-4 auth-form-title">Login</h1>

        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label auth-form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label auth-form-label"></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary auth-submit-btn">Login</button>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary auth-secondary-btn">Register</a>
            </div>
        </form>
    </section>
</div>

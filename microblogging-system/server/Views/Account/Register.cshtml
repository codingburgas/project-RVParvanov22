@model MicrobloggingSystem.Models.DTOs.Auth.RegisterDto

<div class="auth-page auth-page-simple">
    <section class="auth-form-shell">
        <h1 class="mb-4 auth-form-title">Register</h1>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="DisplayName" class="form-label auth-form-label"></label>
                <input asp-for="DisplayName" class="form-control" placeholder="Your gamer name" />
                <span asp-validation-for="DisplayName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label auth-form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label auth-form-label"></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="At least 6 characters" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label auth-form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary auth-submit-btn">Register</button>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary auth-secondary-btn">Login</a>
            </div>
        </form>
    </section>
</div>

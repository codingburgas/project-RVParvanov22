<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Microblogging System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-..." crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon">MP</div>
                <div class="sidebar-logo-text">PlayerPulse</div>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index" class="sidebar-nav-item">
                    <i class="fas fa-home"></i>
                    <span>Feed</span>
                </a>

                <a asp-controller="PostsMvc" asp-action="Create" class="sidebar-nav-item">
                    <i class="fas fa-feather"></i>
                    <span>Create Post</span>
                </a>

                <a asp-controller="Search" asp-action="Index" class="sidebar-nav-item">
                    <i class="fas fa-search"></i>
                    <span>Search</span>
                </a>

                <a asp-controller="Home" asp-action="Reports" class="sidebar-nav-item">
                    <i class="fas fa-chart-bar"></i>
                    <span>Reports</span>
                </a>

            </nav>

            <!-- User Section at Bottom -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="sidebar-user-section">
                    <a asp-controller="Account" asp-action="Profile" class="user-profile-card">
                        @{
                            var displayName = User.FindFirst("displayName")?.Value ?? User.Identity?.Name ?? "User";
                            var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;
                        }
                        
                        <div class="user-avatar-placeholder-small">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </div>

                        <div class="user-info">
                            <div class="user-name" title="@displayName">@displayName</div>
                            <div class="user-email" title="@userEmail">@userEmail</div>
                        </div>
                    </a>

                    <form method="post" asp-controller="Account" asp-action="Logout" class="logout-form">
                        <button type="submit" title="Logout">
                            <i class="fas fa-sign-out-alt"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="sidebar-user-section auth-sidebar-section">
                    <div class="auth-sidebar-title">Account</div>
                    <a asp-controller="Account" asp-action="Register" class="sidebar-nav-item auth-sidebar-item auth-sidebar-item-primary">
                        <i class="fas fa-user-plus"></i>
                        <span>Register</span>
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="sidebar-nav-item auth-sidebar-item">
                        <i class="fas fa-sign-in-alt"></i>
                        <span>Login</span>
                    </a>
                </div>
            }
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <nav class="navbar navbar-expand-lg navbar-custom">
                <div class="container-fluid">
                    <a asp-controller="Home" asp-action="Index" class="navbar-brand">PlayerPulse</a>

                    <div class="topbar-actions">
                        <!-- Search Bar -->
                        <form method="get" asp-controller="Search" asp-action="Index" class="d-flex me-3">
                            <div class="input-group">
                                <input type="text"
                                       name="q"
                                       class="form-control form-control-sm"
                                       placeholder="Search..."
                                       style="width: 200px;">
                                <button class="btn btn-outline-light btn-sm" type="submit">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </form>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="PostsMvc" asp-action="Drafts" class="topbar-link">
                                <i class="fas fa-edit"></i>
                                <span>Drafts</span>
                            </a>
                            <a asp-controller="Account" asp-action="Profile" class="topbar-link">
                                <i class="fas fa-user"></i>
                                <span>Profile</span>
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="topbar-link">
                                <i class="fas fa-sign-in-alt"></i>
                                <span>Login</span>
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="topbar-link topbar-link-primary">
                                <i class="fas fa-user-plus"></i>
                                <span>Register</span>
                            </a>
                        }
                    </div>
                </div>
            </nav>

            <div class="content-area">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-..." crossorigin="anonymous"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

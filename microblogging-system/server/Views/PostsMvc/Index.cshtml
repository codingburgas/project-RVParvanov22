@model IEnumerable<MicrobloggingSystem.Models.DTOs.PostResponseDto>

@section Styles {
    <link rel="stylesheet" href="~/css/feed.css" asp-append-version="true" />
}

<h1 class="mb-4 feed-page-title">All Posts</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">There are no posts yet. Create the first one.</div>
}
else
{
    foreach (var post in Model)
    {
        <article class="feed-card">
            <div class="feed-card-top">
                <div>
                    <div class="feed-card-game">@post.GameTitle</div>
                    <h3 class="feed-card-author">
                        <a asp-controller="Account" asp-action="Profile" asp-route-id="@post.UserId">
                            @post.UserDisplayName
                        </a>
                    </h3>
                    <p class="feed-card-date">@post.CreatedAt.ToLocalTime().ToString("g")</p>
                </div>
                <span class="feed-post-type">@post.PostType ?? "General"</span>
            </div>
            <p class="feed-card-content">@post.Content</p>
            @if (!string.IsNullOrWhiteSpace(post.MediaPath) && string.Equals(post.MediaType, "video", StringComparison.OrdinalIgnoreCase))
            {
                <video class="post-video" controls preload="metadata">
                    <source src="@post.MediaPath" />
                </video>
            }
            <div class="feed-card-stats">
                <span>@post.CommentsCount comments</span>
                <span>@post.LikesCount likes</span>
            </div>
            <a class="btn btn-primary btn-sm mt-3" asp-action="Details" asp-route-id="@post.Id">View</a>
        </article>
    }
}

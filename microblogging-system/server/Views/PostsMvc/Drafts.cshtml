@model IEnumerable<MicrobloggingSystem.Models.DTOs.PostResponseDto>

@section Styles {
    <link rel="stylesheet" href="~/css/feed.css" asp-append-version="true" />
}

<h1 class="mb-4 feed-page-title">My Drafts</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You don't have any draft posts yet.
        <a asp-action="Create" class="alert-link">Create your first draft</a>.
    </div>
}
else
{
    var currentUserId = ViewBag.CurrentUserId as string;
    foreach (var post in Model)
    {
        <article class="feed-card">
            <div class="feed-card-top">
                <div>
                    <div class="feed-card-game">@post.GameTitle</div>
                    <h3 class="feed-card-author">
                        <a asp-controller="Account" asp-action="Profile" asp-route-id="@post.UserId">
                            @post.UserDisplayName
                        </a>
                    </h3>
                    <p class="feed-card-date">@post.CreatedAt.ToLocalTime().ToString("g")</p>
                    <span class="badge badge-secondary">Draft</span>
                </div>
                <span class="feed-post-type">@post.PostType ?? "General"</span>
            </div>
            <p class="feed-card-content">@post.Content</p>
            @if (!string.IsNullOrWhiteSpace(post.MediaPath) && string.Equals(post.MediaType, "video", StringComparison.OrdinalIgnoreCase))
            {
                <video class="post-video" controls preload="metadata">
                    <source src="@post.MediaPath" />
                </video>
            }
            <div class="feed-card-stats">
                <span>@post.CommentsCount comments</span>
                <span>@post.LikesCount likes</span>
            </div>
            <div class="feed-card-actions">
                <a class="btn btn-primary btn-sm" asp-action="Details" asp-route-id="@post.Id">View</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@post.Id">Edit</a>
                <form asp-action="PublishDraft" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@post.Id" />
                    <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Are you sure you want to publish this draft?')">Publish</button>
                </form>
                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this draft? This action cannot be undone.')">
                    <input type="hidden" name="id" value="@post.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </div>
        </article>
    }
}

<div class="mt-4">
    <a asp-action="Create" class="btn btn-primary">Create New Post</a>
    <a asp-controller="PostsMvc" asp-action="Index" class="btn btn-outline-secondary ml-2">View All Posts</a>
</div>
@model MicrobloggingSystem.Models.ViewModels.PostDetailsViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/feed.css" asp-append-version="true" />
}

<h1 class="mb-4 feed-page-title">Post Details</h1>

<article class="feed-card feed-card-detail">
    <div class="feed-card-top">
        <div>
            <div class="feed-card-game">@Model.Post.GameTitle</div>
            <h3 class="feed-card-author">
                <a asp-controller="Account" asp-action="Profile" asp-route-id="@Model.Post.UserId">
                    @Model.Post.UserDisplayName
                </a>
            </h3>
            <p class="feed-card-date">@Model.Post.CreatedAt.ToLocalTime().ToString("g")</p>
        </div>
        <span class="feed-post-type">@Model.Post.PostType ?? "General"</span>
    </div>

    <p class="feed-card-content">@Model.Post.Content</p>

    @if (!string.IsNullOrWhiteSpace(Model.Post.MediaPath) && string.Equals(Model.Post.MediaType, "video", StringComparison.OrdinalIgnoreCase))
    {
        <video class="post-video" controls preload="metadata">
            <source src="@Model.Post.MediaPath" />
        </video>
    }

    <div class="feed-card-stats">
        <span>@Model.Post.CommentsCount comments</span>
        <span>@Model.Post.LikesCount likes</span>
    </div>

    <div class="feed-card-actions">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="SocialMvc" asp-action="ToggleLike" method="post" class="d-inline">
                <input type="hidden" name="postId" value="@Model.Post.Id" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <button type="submit" class="btn btn-sm @(Model.IsLikedByCurrentUser ? "btn-success" : "btn-outline-primary")">
                    @(Model.IsLikedByCurrentUser ? "Liked" : "Like")
                </button>
            </form>

            @if (!Model.IsOwnPost)
            {
                <form asp-controller="SocialMvc" asp-action="ToggleFollow" method="post" class="d-inline">
                    <input type="hidden" name="targetUserId" value="@Model.Post.UserId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" class="btn btn-sm @(Model.IsFollowingAuthor ? "btn-outline-danger" : "btn-outline-secondary")">
                        @(Model.IsFollowingAuthor ? "Unfollow Player" : "Follow Player")
                    </button>
                </form>
            }
        }

        @if (Model.IsOwnPost)
        {
            <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="btn btn-outline-primary btn-sm">Edit</a>
            <form asp-action="Delete" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
            </form>
        }
    </div>
</article>

<section class="comment-section">
    <h2 class="h5">Comments</h2>

    @if (!Model.Comments.Any())
    {
        <div class="feed-empty">No comments yet. Be the first to respond.</div>
    }
    else
    {
        <div class="comment-list">
            @foreach (var comment in Model.Comments)
            {
                <div class="comment-card">
                    <p class="mb-1">@comment.Content</p>
                    <div class="small text-muted">@comment.UserDisplayName · @comment.CreatedAt.ToLocalTime().ToString("g")</div>
                </div>
            }
        </div>
    }

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="auth-form-shell mt-4">
            <h5 class="card-title">Add a comment</h5>
            <form asp-controller="CommentMvc" asp-action="Create" method="post">
                <input asp-for="NewComment.PostId" type="hidden" />
                <div class="mb-3">
                    <textarea asp-for="NewComment.Content" class="form-control" rows="3" maxlength="280"></textarea>
                    <span asp-validation-for="NewComment.Content" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Post Comment</button>
            </form>
        </div>
    }
    else
    {
        <div class="feed-empty mt-4">Please <a asp-controller="Account" asp-action="Login">login</a> to comment.</div>
    }
</section>
